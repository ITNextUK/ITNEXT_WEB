{
  "info": {
    "name": "ITNEXT API",
    "description": "API endpoints for ITNEXT platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "default"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', response.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@itnext.uk\",\n    \"password\": \"changethispassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"currentPassword\": \"changethispassword123\",\n    \"newPassword\": \"newSecurePassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/password"
          }
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Get All Content",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/content"
          }
        },
        {
          "name": "Update Content",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"hero\": {\n        \"title\": \"Updated Title\",\n        \"subtitle\": \"Updated subtitle\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/content"
          }
        },
        {
          "name": "Update Section",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated Hero Title\",\n    \"subtitle\": \"Updated subtitle\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/content/hero"
          }
        }
      ]
    },
    {
      "name": "Insights",
      "item": [
        {
          "name": "Get All Insights",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/insights?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["insights"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "AI Automation",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "agent",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Insight by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/insights/sample-post-slug"
          }
        },
        {
          "name": "Create Insight",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"New Insight Title\",\n    \"category\": \"AI Automation & Intelligent Systems\",\n    \"excerpt\": \"This is a brief excerpt of the insight\",\n    \"featureImage\": \"https://images.unsplash.com/photo-1485827404703-89b55fcc595e\",\n    \"author\": \"ITNEXT Team\",\n    \"readingTime\": \"5 min read\",\n    \"tags\": [\"AI\", \"Automation\"],\n    \"status\": \"published\",\n    \"body\": [\n        {\n            \"type\": \"heading\",\n            \"content\": \"Introduction\"\n        },\n        {\n            \"type\": \"text\",\n            \"content\": \"This is the main content of the post.\"\n        }\n    ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/insights"
          }
        },
        {
          "name": "Update Insight",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated Title\",\n    \"status\": \"published\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/insights/:id"
          }
        },
        {
          "name": "Delete Insight",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/insights/:id"
          }
        },
        {
          "name": "Like Insight",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/insights/:id/like"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/upload/image"
          }
        },
        {
          "name": "Upload Multiple Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/upload/images"
          }
        },
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/upload/file"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
